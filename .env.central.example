# nomotactic central environment variables
# Copy to .env.central: cp .env.central.example .env.central
# .env.central is gitignored — never commit secrets.

# Base URL for the central-mode API (fleet management).
# Must match the Tailscale MagicDNS FQDN in the TLS cert.
EXPO_PUBLIC_CENTRAL_API_URL=https://your-server.tailXXXXX.ts.net:8443
