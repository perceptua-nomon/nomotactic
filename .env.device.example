# nomotactic device environment variables
# Copy to .env.device: cp .env.device.example .env.device
# .env.device is gitignored — never commit secrets.

# Base URL for the device-mode API on the Raspberry Pi.
# Must use HTTPS. Example Tailscale MagicDNS URLs shown.
EXPO_PUBLIC_DEVICE_API_URL=https://your-pi.tailXXXXX.ts.net:8443
